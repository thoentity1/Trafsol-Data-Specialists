  margin:40px auto;
  padding:40px;
  background: rgba(255,255,255,0.05);
  border-radius:20px;
  backdrop-filter: blur(12px);
  box-shadow:0 0 25px rgba(6,182,212,0.2);
}

.container h3{
  color:#22d3ee;
}

/* GRID */

.grid{
  display:grid;
  grid-template-columns: repeat(auto-fit, minmax(260px,1fr));
